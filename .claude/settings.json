{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "${CLAUDE_PROJECT_DIR}"]
    }
  },
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(glab *)",
      "Bash(gradle *)",
      "Bash(./gradlew *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(mvn *)",
      "Bash(dotnet *)",
      "Bash(ng *)",
      "Bash(ktlint *)",
      "Bash(spectral *)",
      "Bash(semgrep *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(echo *)",
      "Bash(chmod +x *)",
      "Bash(python3 *)",
      "Bash(bash *)",
      "Bash(node *)",
      "Bash(sort *)",
      "Bash(awk *)",
      "Bash(xargs *)",
      "Bash(mkdir -p *)",
      "Bash(cp -r *)",
      "Bash(./.claude/scripts/create-branch.sh *)",
      "Bash(./.claude/scripts/quality-check.sh *)",
      "Bash(./.claude/scripts/squash-rebase.sh *)",
      "Skill(learn)",
      "Skill(pr-reviewer)",
      "mcp__github__*",
      "mcp__filesystem__*"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(git push --force origin main)",
      "Bash(git push --force origin master)",
      "Bash(curl * | bash)",
      "Bash(eval *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/session-start.sh",
            "timeout": 15,
            "statusMessage": "Loading project context..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/safety-bash.sh",
            "timeout": 5,
            "statusMessage": "Safety check..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/commit-guard.sh",
            "timeout": 10,
            "statusMessage": "Checking commit message..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/post-tool-audit.sh",
            "async": true
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/post-edit-secrets.sh",
            "timeout": 10,
            "statusMessage": "Scanning for secrets..."
          },
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/post-edit-openapi.sh",
            "timeout": 20,
            "statusMessage": "Linting OpenAPI spec..."
          }
        ]
      }
    ],
    "FileChanged": [
      {
        "matcher": "\\.env$|\\.env\\.",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/file-changed-env.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Bash|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/post-tool-audit.sh",
            "async": true
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"systemMessage\": \"About to compact. Consider whether any in-progress decisions, open questions, or state-machine positions need to be preserved in MEMORY.md before context is reduced.\"}'",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/stop-audit.sh",
            "async": true
          }
        ]
      }
    ]
  },
  "alwaysThinkingEnabled": true,
  "cleanupPeriodDays": 90,
  "env": {
    "ISSUE_TRACKER": "github",
    "APPROVAL_LABEL": "approved",
    "COVERAGE_THRESHOLD": "80",
    "DEFAULT_BRANCH": "main",
    "SESSION_LOG_DIR": "~/.claude/kbeatz-sessions"
  },
  "enabledPlugins": {
    "kotlin-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  }
}
